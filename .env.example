# ── Discord ────────────────────────────────────────────────────
# Get these from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here

# Guild ID for fast (guild-scoped) command deployment during development.
# Remove or leave blank to deploy commands globally.
DISCORD_GUILD_ID=your_guild_id_here

# ── Blizzard Battle.net API ─────────────────────────────────────
# Create a client at https://develop.battle.net
# Set the Redirect URI to: http://localhost
BLIZZARD_CLIENT_ID=your_blizzard_client_id_here
BLIZZARD_CLIENT_SECRET=your_blizzard_client_secret_here

# ── Bot Settings ────────────────────────────────────────────────
# Default WoW region (us / eu / kr / tw)
WOW_REGION=us

# ── Hosting ─────────────────────────────────────────────────────
# On Railway: set this to /data/silvermoon.db and mount a volume at /data
# Leave blank locally (defaults to project root)
DATABASE_PATH=

# ── Web Dashboard ────────────────────────────────────────────────
# Random string used to sign session cookies — keep this secret
SESSION_SECRET=change_this_to_a_random_string

# Full URL to your Railway deployment + /auth/callback
# e.g. https://twic-silvermoon-bot.up.railway.app/auth/callback
# Also add this exact URL to your Discord app's OAuth2 Redirect URIs
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback
